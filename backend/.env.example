# Server
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080   # used to build Vapi serverUrl; use ngrok URL for real calls

# Database (SQLite for local dev; swap to a postgresql:// URL + provider in prod)
DATABASE_URL="file:./dev.db"

# Pricing / caps
SESSION_PRICE_CENTS=500
MAX_CALLS_PER_SESSION=3
MINUTES_CAP_PER_SESSION=60
ENFORCE_BUSINESS_HOURS=false   # set true in prod to only call Mon–Fri 9–5 in the office's timezone

# Vapi
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Metriport (health-records aggregator). Leave AGGREGATOR_API_KEY blank to keep records in mock mode.
# Sandbox: AGGREGATOR_BASE_URL=https://api.sandbox.metriport.com (facility test NPI 1234567893).
# Register the webhook in the Metriport dashboard as <PUBLIC_BASE_URL>/webhooks/aggregator and set the
# same key as AGGREGATOR_WEBHOOK_SECRET (verifies the x-metriport-signature HMAC on each delivery).
AGGREGATOR_API_KEY=
AGGREGATOR_WEBHOOK_SECRET=
AGGREGATOR_BASE_URL=https://api.metriport.com
AGGREGATOR_FACILITY_ID=
AGGREGATOR_CONNECT_URL=https://connect.metriport.com

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM="Klove <noreply@klove.app>"

# Google Places (phone + website lookup; also physician-search ratings)
GOOGLE_PLACES_API_KEY=

# Physician search ("best expert for my condition"). The NPI Registry is a free, keyless public US API,
# so this is an explicit opt-in (off → deterministic seeded specialists for dev/demo). Set to true to
# query the live registry; Google Places (ratings) + an LLM (specialty routing) layer on when configured.
PHYSICIAN_SEARCH_LIVE=false

# Web-automation agent (Playwright + Claude). Needs: ANTHROPIC_API_KEY set, and a one-time
# `npx playwright install chromium` to download the browser. Leave key blank to keep web in mock.
ANTHROPIC_API_KEY=
WEB_AGENT_MODEL=claude-opus-4-8
WEB_AGENT_MAX_STEPS=25
