{
  "name": "klove-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Klove backend — the operating system for family health (health concierge / Chief of Staff)",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "backfill-households": "tsx --env-file=.env scripts/backfill-households.ts",
    "import-household": "tsx --env-file=.env scripts/import-household-backup.ts",
    "create-assistant": "tsx --env-file=.env scripts/create-vapi-assistant.ts",
    "send-summary": "tsx --env-file=.env scripts/send-summary.ts",
    "recon-web": "tsx --env-file=.env scripts/recon-web.ts",
    "seed:e2e": "tsx --env-file=.env scripts/seed-e2e.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@fastify/multipart": "^8.3.0",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "fastify": "^4.28.1",
    "imapflow": "^1.4.0",
    "mailparser": "^3.9.9",
    "pino": "^10.3.1",
    "playwright": "^1.60.0",
    "qrcode-terminal": "^0.12.0",
    "resend": "^4.0.1",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "esbuild@0.28.1": true,
    "prisma@5.22.0": true
  }
}
