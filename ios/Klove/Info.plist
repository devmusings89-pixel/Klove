<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Klove</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>app.klove.client</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>klove</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSCameraUsageDescription</key>
	<string>Klove uses the camera to capture photos of lab results, insurance cards, and other health documents.</string>
	<key>NSHealthClinicalHealthRecordsShareUsageDescription</key>
	<string>Klove imports clinical records from the Health app so your family's lab results, conditions, and medications are all in one place.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>Klove reads your family's health records, lab results, and vitals to keep each member's timeline up to date and surface things to discuss with your provider.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Klove does not write to Apple Health; this access is requested only so the app can read your family's health records to keep their timelines up to date.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Klove uses the microphone so you can speak to your health concierge, like "book Mom a dermatology visit".</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Klove transcribes what you say on this device so it can understand the request you want handled.</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
