# ---- OS ----
.DS_Store
**/.DS_Store

# ---- Local agent / editor state ----
.claude/

# ---- Secrets: never commit real env files (templates like .env.example are tracked) ----
.env
*.env

# ---- Node / backend ----
**/node_modules/
backend/dist/

# ---- Databases (local dev) ----
*.db
*.db-journal
backend/prisma/dev.db*

# ---- Runtime artifacts / local storage (PHI — never commit) ----
**/.uploads/
backend/snakecase-backup.json

# ---- Xcode / iOS (Klove.xcodeproj is generated from project.yml by xcodegen) ----
ios/build/
ios/Klove.xcodeproj/
ios/Svasa.xcodeproj/
**/xcuserdata/
**/*.xcuserstate
**/.swiftpm/
DerivedData/
*.xcarchive

# ---- WhatsApp (Baileys) session credentials — sensitive, never commit ----
**/.baileys-auth/
**/.baileys-probe/

# ---- QA agent run output (screenshots + reports) — keep the dir, not the runs ----
qa/reports/*
!qa/reports/.gitkeep
